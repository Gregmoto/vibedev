# Databas
# Transaction pooler (pgbouncer) — används av appen i runtime
DATABASE_URL="postgresql://postgres.[projekt-ref]:[lösenord]@aws-0-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — används ENDAST av Prisma migrate/generate
DIRECT_URL="postgresql://postgres.[projekt-ref]:[lösenord]@aws-0-eu-north-1.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_SECRET="generera-med-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin-konto (används vid seeding)
ADMIN_EMAIL="admin@vibedev.se"
ADMIN_PASSWORD="byt-till-starkt-losenord"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# E-post (Resend)
RESEND_API_KEY=""
CONTACT_EMAIL_TO="hello@vibedev.se"
# OBS: from-adressen kräver en verifierad domän i Resend.
# Under utveckling kan du använda: onboarding@resend.dev
CONTACT_EMAIL_FROM="noreply@vibedev.se"
