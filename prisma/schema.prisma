generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EDITOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  role          UserRole  @default(ADMIN)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String
  content         Json
  featuredImage   String?
  author          String?
  category        String
  tags            String[]
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  metaDescription String?
  ogTitle         String?
  ogDescription   String?
  canonicalUrl    String?
  noindex         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

model PodcastEpisode {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  description     String
  showNotes       Json
  guestNames      String[]
  coverImage      String?
  audioUrl        String?
  embedUrl        String?
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  metaDescription String?
  ogTitle         String?
  ogDescription   String?
  canonicalUrl    String?
  noindex         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
}

model CaseStudy {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  clientName      String?
  industry        String
  summary         String
  problem         String
  solution        String
  process         Json
  results         Json
  techStack       String[]
  featuredImage   String?
  status          ContentStatus @default(DRAFT)
  publishedAt     DateTime?
  seoTitle        String?
  metaDescription String?
  ogTitle         String?
  ogDescription   String?
  canonicalUrl    String?
  noindex         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([industry])
}

model Page {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  intro           String?
  content         Json
  status          ContentStatus @default(DRAFT)
  seoTitle        String?
  metaDescription String?
  ogTitle         String?
  ogDescription   String?
  canonicalUrl    String?
  noindex         Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
}

model SiteSettings {
  id                               String   @id @default(cuid())
  siteName                         String   @default("VibeDev")
  siteUrl                          String   @default("https://vibedev.se")
  contactEmail                     String?
  phone                            String?
  address                          String?
  footerText                       String?
  socialLinks                      Json?
  defaultSeoTitle                  String?
  defaultMetaDescription           String?
  ga4MeasurementId                 String?
  ga4CustomScript                  String?
  googleSearchConsoleVerification  String?
  createdAt                        DateTime @default(now())
  updatedAt                        DateTime @updatedAt
}
